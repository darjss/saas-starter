{
  "name": "saas-starter",
  "type": "module",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "typecheck": "astro check",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "check": "astro check && oxlint",
    "auth:generate": "better-auth generate --output src/server/db/auth-schema.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply saas-starter-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply saas-starter-db --remote",
    "seed": "tsx scripts/seed.ts",
    "polar:setup": "tsx scripts/polar-setup.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.1",
    "@astrojs/solid-js": "^7.0.1",
    "@better-auth/sso": "^1.6.23",
    "@corvu/drawer": "^0.2.4",
    "@fontsource-variable/inter": "^5.2.8",
    "@kobalte/core": "^0.13.12",
    "@paralleldrive/cuid2": "^3.3.0",
    "@polar-sh/better-auth": "^1.8.4",
    "@polar-sh/sdk": "^0.48.1",
    "@solidjs/router": "^0.16.1",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/solid-query": "^5.101.2",
    "astro": "^7.0.6",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "lucide-solid": "^1.23.0",
    "solid-js": "^1.9.13",
    "solid-sonner": "^0.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@better-auth/cli": "^1.4.21",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.24",
    "wrangler": "^4.107.0"
  }
}
