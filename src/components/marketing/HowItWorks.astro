---
const steps = [
  { step: "1", title: "Sign up", body: "Create an account with email, magic link, or Google." },
  { step: "2", title: "Create a project", body: "Everything is scoped to your account and org." },
  { step: "3", title: "Upgrade when ready", body: "One click to Polar checkout, no surprises." },
];
---

<section id="how-it-works" class="bg-muted/40 py-20">
  <div class="mx-auto max-w-5xl px-6">
    <h2 class="text-center text-3xl font-bold tracking-tight">How it works</h2>
    <div class="mt-12 grid gap-8 md:grid-cols-3">
      {
        steps.map((item) => (
          <div class="text-center">
            <div class="bg-primary text-primary-foreground mx-auto flex size-10 items-center justify-center rounded-full font-semibold">
              {item.step}
            </div>
            <h3 class="mt-4 font-semibold">{item.title}</h3>
            <p class="text-muted-foreground mt-2 text-sm">{item.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
