---
import { plans } from "@/lib/plans";
---

<section id="pricing" class="mx-auto max-w-5xl px-6 py-20">
  <h2 class="text-center text-3xl font-bold tracking-tight">Simple pricing</h2>
  <div class="mt-12 grid gap-8 sm:grid-cols-2">
    {
      plans.map((plan) => (
        <div class:list={["rounded-lg border p-6", plan.highlighted && "border-primary"]}>
          <h3 class="font-semibold">{plan.name}</h3>
          <p class="mt-2 text-3xl font-bold">
            ${plan.priceMonthly}
            <span class="text-muted-foreground text-sm font-normal">/mo</span>
          </p>
          <p class="text-muted-foreground mt-2 text-sm">{plan.description}</p>
        </div>
      ))
    }
  </div>
  <p class="mt-8 text-center">
    <a href="/pricing" class="text-primary underline underline-offset-4">See full pricing</a>
  </p>
</section>
