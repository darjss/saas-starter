---
const features = [
  {
    title: "Auth that just works",
    body: "Email, magic links, 2FA, Google, and organizations via better-auth on D1.",
  },
  {
    title: "Billing built in",
    body: "Polar checkout, customer portal, and webhooks wired through better-auth.",
  },
  {
    title: "Typed end to end",
    body: "Elysia API with an Eden client. Errors arrive as a typed union, not surprises.",
  },
  {
    title: "Edge native",
    body: "Astro SSR on Cloudflare Workers with D1, KV sessions, and edge caching.",
  },
];
---

<section id="features" class="mx-auto max-w-5xl px-6 py-20">
  <h2 class="text-center text-3xl font-bold tracking-tight">Everything you need to launch</h2>
  <div class="mt-12 grid gap-8 sm:grid-cols-2">
    {
      features.map((feature) => (
        <div class="rounded-lg border p-6">
          <h3 class="font-semibold">{feature.title}</h3>
          <p class="text-muted-foreground mt-2 text-sm">{feature.body}</p>
        </div>
      ))
    }
  </div>
</section>
