---
import Footer from "@/components/marketing/Footer.astro";
import { PlanCard } from "@/components/marketing/PlanCard";
import Layout from "@/layouts/Layout.astro";
import { plans } from "@/lib/plans";
---

<Layout title="Pricing — SaaS Starter">
  <main class="mx-auto max-w-4xl px-6 py-20">
    <h1 class="text-center text-4xl font-bold tracking-tight">Pricing</h1>
    <p class="text-muted-foreground mt-4 text-center">
      Start free, upgrade when you outgrow it.
    </p>
    <div class="mt-12 grid gap-8 sm:grid-cols-2">
      {plans.map((plan) => <PlanCard client:load plan={plan} />)}
    </div>
  </main>
  <Footer />
</Layout>
